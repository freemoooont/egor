# API target for the dev proxy (override via .env / .env.local). Defaults to
# the Go API listening on the loopback in dev mode.
VITE_API_TARGET=http://127.0.0.1:8080

# Optional override for the resolved API base used at runtime.
# Leave unset to use the dev-server proxy in dev and `/api` (same-origin) in prod.
# VITE_API_BASE=https://v811467.hosted-by-vdsina.com/api
